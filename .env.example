# Cal.com / Cal.eu MCP server configuration.
# Copy to .env.local (auto-loaded from the project root on startup), or set these
# in your MCP client's `env` block. Client env always overrides the file.
# .env.local / .env are gitignored. NEVER commit a real key.

# Required: your Cal API key (sent as `Authorization: Bearer <key>`).
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: API base URL. Defaults to the Cal.eu host.
CALCOM_BASE_URL=https://api.cal.eu

# Optional: fallback cal-api-version. Each endpoint family already has a known-good
# default (event-types 2024-06-14, bookings 2024-08-13, slots 2024-09-04,
# schedules 2024-06-11); this only applies to endpoints without one and to
# cal_api_request when no per-call apiVersion is passed.
CALCOM_API_VERSION=2024-08-13

# Optional: per-request timeout in milliseconds (default 30000).
CALCOM_TIMEOUT_MS=30000

# Optional: set to 1/true to log redacted request/response info to stderr.
CALCOM_DEBUG=
